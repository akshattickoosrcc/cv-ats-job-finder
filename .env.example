# ─────────────────────────────────────────────────────────────────
#  Backend (VPS) environment — copy to .env and fill in.
#  These are read by BOTH the web (gunicorn) and worker processes.
# ─────────────────────────────────────────────────────────────────

# Flask signed-cookie / admin secret. Generate: python3 -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-hex-string

# CORS: the exact origin(s) of your static frontend on Vercel. Comma-separated.
# Use your real Vercel domain (and custom domain if any). NOT "*" in production.
FRONTEND_ORIGIN=https://your-app.vercel.app

# Queue backend: "redis" in production, "sqlite" for local/dev without Redis.
QUEUE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0

# Where the SQLite job cache + uploads live (a real directory on the VPS disk).
DATA_DIR=/var/lib/cvfinder
UPLOAD_DIR=/var/lib/cvfinder/uploads

# Web sizing (see gunicorn.conf.py). Match to your box's RAM.
PORT=8000
WEB_WORKERS=3
WEB_THREADS=8

# Burst handling: show "you're #X in queue" once this many jobs are pending.
MAX_QUEUE_DEPTH=40

# Worker
PARSE_TIMEOUT=25            # seconds to extract text before failing a job
PARSE_MEM_LIMIT_MB=512      # address-space cap for the parse subprocess
WORKER_STALE_SECONDS=120    # /health fails if worker heartbeat older than this
WORKER_SCRAPE=1             # worker keeps the job cache warm
SCRAPE_MODE=full           # "full" (VPS, more sources) or "light" (low RAM)
SCRAPE_INTERVAL_HOURS=6

# PDF text extractor: pymupdf (fast, AGPL) | pdfplumber | pypdf (BSD, fast).
# Set to "pypdf" if AGPL licensing is a concern for your commercial product.
PDF_EXTRACTOR=pymupdf
